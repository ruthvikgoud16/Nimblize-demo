# Nimblize - Environment Variables Template
# Copy to .env and fill in real values. Never commit .env to Git.

# ─── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://nimblize:nimblize_dev@localhost:5432/nimblize
POSTGRES_PASSWORD=nimblize_dev

# ─── Redis ────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── OpenAI ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production

# ─── Notifications ────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/X000
SENDGRID_API_KEY=SG...
PAGERDUTY_ROUTING_KEY=...

# ─── Telemetry ────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_PORT=9090

# ─── Grafana ──────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=nimblize_admin

# ─── App ──────────────────────────────────────────────────────────────────
ENV=development
ALLOWED_ORIGINS=http://localhost:3000,https://app.nimblize.ai
